# Phase 9 E2E test environment.
# Copy this file to .env.e2e.local (gitignored) and fill in real values.
# For CI, the same vars come from GitHub Actions secrets.
#
# See docs/phase9/fixture-user.md for what these are and how to obtain them.

# OAuth2 client credentials for connect-id /users/generate_manual_otp
CONNECTID_E2E_CLIENT_ID=
CONNECTID_E2E_CLIENT_SECRET=

# The single fixture phone number, including +country code prefix.
# Must use the +7426 test-number prefix (e.g., +74260000NNN) so connect-id
# bypasses SMS delivery via TEST_NUMBER_PREFIX in users/const.py.
CONNECTID_E2E_PHONE=

# The phone number digits AFTER the country code, no +. Used by Maestro
# UI input where the country code is entered separately.
# Example: if CONNECTID_E2E_PHONE=+74260000001, set this to 4260000001.
CONNECTID_E2E_PHONE_LOCAL=

# Fixture user's backup code (captured during manual registration in Task 0.2).
CONNECTID_E2E_BACKUP_CODE=

# Fixture user's PIN (captured during manual registration in Task 0.2).
CONNECTID_E2E_PIN=

# The country code portion of the fixture phone number, with leading +.
# Example: if CONNECTID_E2E_PHONE=+74260000001, set this to +7.
# Currently the fixture is a Russian test number (+7426 prefix); when
# adding fixtures in other regions, set appropriately.
CONNECTID_E2E_COUNTRY_CODE=+7

# connect-id base URL (override only for staging, which doesn't currently exist)
CONNECTID_E2E_BASE_URL=https://connectid.dimagi.com

# -----------------------------------------------------------------------------
# Phase 9 Wave 3+ CommCare HQ test app
# -----------------------------------------------------------------------------
# Bonsaaso Application in jonstest domain. See docs/phase9/fixture-user.md
# for provenance. Profile URL is anonymous-accessible (no auth required to
# download the .ccpr). Login requires the mobile worker credentials below.

COMMCARE_HQ_URL=https://www.commcarehq.org
COMMCARE_DOMAIN=jonstest
COMMCARE_APP_ID=1399c28e016a1ede7228056de4ebb1f5
COMMCARE_APP_PROFILE_URL=https://www.commcarehq.org/a/jonstest/apps/download/1399c28e016a1ede7228056de4ebb1f5/profile.ccpr

# Web/HQ admin (used for API discovery only — not the mobile login)
COMMCARE_HQ_WEB_USERNAME=
COMMCARE_HQ_WEB_PASSWORD=

# Mobile worker (what the iOS app logs in with).
# Either the short form ("haltest") or the full form
# ("haltest@jonstest.commcarehq.org") works — since #391 was fixed, the
# iOS app resolves the short form using the installed app's domain and
# expands it to the full form before sending Basic auth.
COMMCARE_MOBILE_USERNAME=
COMMCARE_MOBILE_PASSWORD=
