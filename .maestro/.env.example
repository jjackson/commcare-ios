COMMCARE_HQ_URL=https://www.commcarehq.org
COMMCARE_USERNAME=user@domain.demo
COMMCARE_PASSWORD=yourpassword
COMMCARE_DOMAIN=yourdomain
COMMCARE_APP_ID=your-app-id-here

# ---
# Phase 9 E2E test secrets (Connect ID UI testing)
#
# These are NOT loaded automatically by Maestro. The Phase 9 fetch-otp.sh
# helper reads them from the parent shell environment. To populate them,
# see .env.e2e.local.example at the repo root.
#
# Required for Phase 9 flows like .maestro/flows/connect-id-recovery.yaml:
#   CONNECTID_E2E_CLIENT_ID
#   CONNECTID_E2E_CLIENT_SECRET
#   CONNECTID_E2E_PHONE
#   CONNECTID_E2E_PHONE_LOCAL
#   CONNECTID_E2E_BACKUP_CODE
#   CONNECTID_E2E_PIN
